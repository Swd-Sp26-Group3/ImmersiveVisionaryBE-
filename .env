PORT=5000
NODE_ENV=production

# SQL Server connection
DB_SERVER=127.0.0.1
DB_NAME=ImmersiveVisionary
DB_USER=sa
DB_PASSWORD=Admin@1234
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_CERT=true

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://www.immersivevisionary.name.vn,https://immersivevisionary.name.vn

# Default admin user created on first run
DEFAULT_ADMIN_EMAIL=admin@electricvehicle.com
DEFAULT_ADMIN_PASSWORD=Admin123!
DEFAULT_ADMIN_ROLE=ADMIN

# VNPAY (leave empty if not used)
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5000/api/payments/vnpay-return