PORT=5000
NODE_ENV=development

# SQL Server connection
DB_SERVER=127.0.0.1
DB_NAME=ImmersiveVisionary
DB_USER=sa
DB_PASSWORD=your_db_password_here
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_CERT=true

# JWT — generate with: node -e "require('crypto').randomBytes(64).toString('hex')" 
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:3000

# Default admin user created on first run
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin123!
DEFAULT_ADMIN_ROLE=ADMIN

# SePay Payment Integration
# API Token: lấy từ my.sepay.vn -> Cấu hình Công ty -> API Access
SEPAY_API_TOKEN=your_sepay_api_token_here
SEPAY_ACCOUNT_NUMBER=your_bank_account_number
SEPAY_BANK=VietinBank
SEPAY_VA=IMV
# Webhook Key: lấy từ SePay Dashboard -> Tích hợp WebHooks -> Token xác thực
SEPAY_API_KEY=your_sepay_webhook_key_here
